@using INTRANET_SSPVER.Models.ViewModels.AvisoPrivacidad
@model AvisoPrivacidadViewModel



@{
	ViewData["Title"] = "Administrar Aviso de Privacidad";
}


@{
	Layout = "~/Views/Shared/_LayoutPublico.cshtml";
}

<style>
	.btn:hover {
		transform: scale(1.05);
		transition: 0.2s;
	}
</style>



<div class="container-fluid mt-4">

	<div class="card shadow-sm border-0">

		<!-- HEADER -->
		<div class="card-header text-white d-flex align-items-center justify-content-between headertitulo">

			<!-- Botón regresar -->
			<a href="javascript:history.back()" class="btn btn-sm btn-light shadow-sm">
				<i class="bi bi-arrow-left"></i> Regresar
			</a>

			<!-- Título centrado -->
			<div class="d-flex align-items-center mx-auto">
				<i class="bi bi-journal-text me-2 fs-4"></i>
				<h4 class="mb-0">Avisos de Privacidad</h4>
			</div>

		</div>

		<div class="card-body">

			<!-- BUSCADOR -->
			<div class="mb-3 position-relative">
				<i class="bi bi-search position-absolute"
				   style="top:10px; left:10px; color:gray;"></i>

				<input type="text" id="searchBox"
					   class="form-control ps-4"
					   placeholder="Buscar por área" />
			</div>

			<!-- ALERTAS -->
			@if (TempData["Success"] != null)
			{
				<div id="alertSuccess" class="alert alert-success alert-dismissible fade show shadow-sm">
					<i class="bi bi-check-circle me-2"></i>
					@TempData["Success"]
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>
			}

			@if (TempData["Error"] != null)
			{
				<div id="alertError" class="alert alert-danger alert-dismissible fade show shadow-sm">
					<i class="bi bi-exclamation-triangle me-2"></i>
					@TempData["Error"]
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>
			}

			<!-- TABLA -->
			<div class="table-responsive">
				<table class="table table-bordered table-hover align-middle" id="tablaDirectorio">

					
					<thead class="text-center" style="background-color:#f1f1f1;">
						<tr>
							<th style="width:10%">#</th>
							<th style="width:40%">Area</th>
							<th style="width:20%">Aviso Integral</th>
							<th style="width:20%">Aviso Simplificado</th>
							<th style="width:10%">Sistema de Datos</th>
							
						</tr>
					</thead>

					<tbody>
						@{
							int i = 1;
						}

						@foreach (var item in Model.Lista)
						{
							<tr>

								<td class="text-center align-middle">@i</td>

								<td class="text-center align-middle">@item.Area</td>

							

								<td class="text-center align-middle">
									@if (!string.IsNullOrEmpty(item.AvisoIntegralUrl))
									{
										<a href="@item.AvisoIntegralUrl" target="_blank"
											   class="btn btn-sm btn-light border rounded-circle shadow-sm"
											   title="Ver PDF">
											<i class="bi bi-file-earmark-pdf text-primary"></i>
										</a>
									}
									else
									{
										<button class="btn btn-sm btn-light border rounded-circle shadow-sm"
												disabled
												title="URL no disponible">
											<i class="bi bi-file-earmark-pdf text-secondary"></i>
										</button>
									}
								</td>

			
								<td class="text-center align-middle">
									@if (!string.IsNullOrEmpty(item.AvisoSimplificadoUrl))
									{
										<a href="@item.AvisoSimplificadoUrl" target="_blank"
											   class="btn btn-sm btn-light border rounded-circle shadow-sm"
											   title="Ver PDF">
											<i class="bi bi-file-earmark-pdf text-primary"></i>
										</a>
									}
									else
									{
										<button class="btn btn-sm btn-light border rounded-circle shadow-sm"
												disabled
												title="URL no disponible">
											<i class="bi bi-file-earmark-pdf text-secondary"></i>
										</button>
									}
								</td>

									
								

								<td class="text-center align-middle">
									@if (!string.IsNullOrEmpty(item.SistemaDatosUrl))
									{
										<a href="@item.SistemaDatosUrl" target="_blank"
											   class="btn btn-sm btn-light border rounded-circle shadow-sm"
											   title="Ver PDF">
											<i class="bi bi-file-earmark-pdf text-primary"></i>
										</a>
									}
									else
									{
										<button class="btn btn-sm btn-light border rounded-circle shadow-sm"
												disabled
												title="URL no disponible">
											<i class="bi bi-file-earmark-pdf text-secondary"></i>
										</button>
									}
								</td>

								
								
								

							</tr>

							i++;
						}

					</tbody>

				</table>
			</div>


		
			<div class="footer-transparencia mt-2 p-4 shadow-sm rounded mb-3">

				<div class="row text-center justify-content-center align-items-center">

					<!-- Área -->
					<div class="col-md-4 mb-3 mb-md-0">
						<div class="info-item d-flex flex-column align-items-center">
							<i class="bi bi-building mb-1 icono"></i>
							<span>
								<strong>Área responsable:</strong><br />
								@Model.Footer.AreaResponsable
							</span>
						</div>
					</div>

					<!-- Fecha -->
					<div class="col-md-4 mb-3 mb-md-0" hidden>
						<div class="info-item d-flex flex-column align-items-center">
							<i class="bi bi-calendar-check mb-1 icono"></i>
							<span>
								<strong>Última actualización:</strong><br />
								@(Model.Footer.FechaActualizacion?.ToString("dd MMMM yyyy") ?? "N/A")
							</span>
						</div>
					</div>

					<!-- Botón -->
				@* 	<div class="col-md-4">
						<div class="d-flex justify-content-center">
							<a href="@Model.Footer.UrlDescarga"
								   class="btn btn-descargar"
								   target="_blank">
								<i class="bi bi-download me-1"></i>
								Descargar listado
							</a>
						</div>
					</div> *@

				</div>

			</div>


		</div>

	</div>






</div>






<script>
	document.getElementById("searchBox").addEventListener("keyup", function () {
		var value = this.value.toLowerCase();
		var rows = document.querySelectorAll("#tablaDirectorio tbody tr");

		let contador = 1;

		rows.forEach(function (row) {
			var text = row.textContent.toLowerCase();

			if (text.includes(value)) {
				row.style.display = "";
				row.cells[0].textContent = contador;
				contador++;
			} else {
				row.style.display = "none";
			}
		});
	});
</script>

										
<script>
	setTimeout(function () {
		let success = document.getElementById("alertSuccess");
		let error = document.getElementById("alertError");

		[success, error].forEach(function (alert) {
			if (alert) {
				alert.classList.remove("show");
				setTimeout(() => alert.remove(), 500);
			}
		});

	}, 3000);
</script>