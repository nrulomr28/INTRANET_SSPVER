@using INTRANET_SSPVER.Models.ViewModels.Transparencia
@* @model List<int> *@
@model ListadoEjercicioVM

@{
	Layout = "~/Views/Shared/_LayoutPublico.cshtml";
}


<style>
	.footer-transparencia {
		background: linear-gradient(135deg, #f8f9fa, #eef1f5);
		/*   border-left: 5px solid #800020;  */
		/* guinda institucional */
	}

	.info-item {
		display: flex;
		align-items: center;
		font-size: 14px;
	}

	.icono {
		font-size: 20px;
		color: #800020;
	}

	.btn-descargar {
		background-color: #800020;
		color: white;
		border-radius: 25px;
		padding: 6px 15px;
		transition: all 0.3s ease;
	}

		.btn-descargar:hover {
			background-color: #a00028;
			transform: translateY(-2px);
		}
</style>




<div class="text-center mb-4">
	<h2 class="fw-bold titulo-principal">
		Comité de Transparencia
	</h2>
	<p class="text-muted">
		Consulta las actas y documentos disponibles por año.
	</p>
	<div class="separador"></div>
</div>



<div class="container mt-4">

	<div class="row">

		@foreach (var anio in Model.Anios)
		{
			<div class="col-md-4 mb-4">
				<a href="@Url.Action("DetalleAnio", "Transparencia", new { anio = anio })" class="text-decoration-none">
					<div class="card text-center shadow-sm h-100 card-hover">
						<div class="card-body">
							<i class="bi bi-folder-symlink-fill text-danger" style="font-size: 50px; color:#6b1f2b !important"></i>
							<h5 class="mt-3 text-dark" style="color:#6b1f2b !important">Año @anio</h5>
						</div>
					</div>
				</a>
			</div>
		}

	</div>



    
	<div class="footer-transparencia mt-2 p-4 shadow-sm rounded mb-3">

		<div class="row align-items-center text-center text-md-start">

			<!-- Área -->
			<div class="col-md-4 mb-2 mb-md-0">
				<div class="info-item">
					<i class="bi bi-building me-2 icono"></i>
					<span><strong>Área responsable:</strong><br /> @Model.AreaResponsable</span>
				</div>
			</div>

			<!-- Fecha -->
			<div class="col-md-4 mb-2 mb-md-0">
				<div class="info-item">
					<i class="bi bi-calendar-check me-2 icono"></i>
					<span>
						<strong>Última actualización:</strong><br />
						@(Model.FechaActualizacion?.ToString("dd MMMM yyyy") ?? "N/A")
					</span>
				</div>
			</div>

			<!-- Botón -->
			<div class="col-md-4 text-md-end">
				<a href="@Model.UrlDescarga"
					   class="btn btn-descargar"
					   target="_blank">
					<i class="bi bi-download me-1"></i>
					Descargar listado
				</a>
			</div>

		</div>

	</div>

    
</div>