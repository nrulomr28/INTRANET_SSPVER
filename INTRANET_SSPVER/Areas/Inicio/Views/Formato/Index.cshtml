@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

	<div class="text-center mb-4 mt-4">
		<h2 class="fw-bold titulo-principal">Formatos</h2>
		<p class="subtitulo">Acceso a formatos institucionales</p>
		<div class="separador"></div>
	</div>

		
	<!-- 🔹 Grid de opciones -->
	<div class="row mt-3 g-4 justify-content-center">

		
		<div class="col-md-3 col-sm-6">
			<a class="card-acceso" href="http://intranet.sspver.gob.mx/#/formatos/permisos" target="_blank">
				<i class="bi bi-pencil-square"></i>
				<h5>Permisos</h5>
				<p>Genera tu formato de permiso</p>
			</a>
		</div>

		<!-- CALEA -->
		<div class="col-md-3 col-sm-6">
			<a class="card-acceso" asp-area="Tecnologias" asp-controller="Formatos" asp-action="Index" asp-route-IdArea_="6	">
				<i class="bi bi-shield-check"></i>
				<h5>Institucionales</h5>
				<p>Descarga elementos para documentación</p>
			</a>
		</div>

		<!-- Formatos -->
		<div class="col-md-3 col-sm-6">
			<a class="card-acceso" asp-area="Tecnologias" asp-controller="Formatos" asp-action="Index" asp-route-IdArea_="5">
				<i class="bi bi-file-earmark-text"></i>
				<h5>Incapacidad</h5>
				<p>Descarga formato de incapacidad</p>
			</a>
		</div>
			
		

	</div>


	<div class="row mt-5">

		<div class="mt-3 text-center mb-3">
			<a asp-area="Inicio" asp-controller="Menu" asp-action="Index" class="btn btn-outline-danger">
				<i class="bi bi-arrow-left-circle me-2"></i> Regresar al menú
			</a>
		</div>

	</div>
		

</div>



