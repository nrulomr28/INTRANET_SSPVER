@model IEnumerable<INTRANET_SSPVER.Models.Entities.Formato>

@{
	Layout = "_Layout";
}

<div class="container-fluid d-flex flex-column align-items-center px-3">

	<!-- Card principal -->
	<div class="w-100 d-flex justify-content-center mt-4">
		<div class="card shadow-sm border-0 w-100 formatos-card">
		
			<div class="card-header bg-secondary text-white d-flex align-items-center justify-content-between">
				
				<a href="/inicio" class="btn btn-sm btn-light">
					<i class="bi bi-arrow-left"></i> Regresar
				</a>
				
				<div class="d-flex align-items-center mx-auto">
					<i class="bi bi-file-earmark-text me-2 fs-4"></i>
					<h4 class="mb-0">@ViewBag.NombreCategoria</h4>
				</div>

				<!-- Espacio para balancear -->
				<div style="width: 90px;"></div>

			</div>


			<div class="card-body text-center mt-4">
				<p class="text-muted">
					Seleccione el formato que desea descargar
					<i class="bi bi-cloud-arrow-down-fill ms-1"></i>
				</p>


				@* 	<h4 class="mb-3 text-primary">
					<i class="bi bi-folder2-open me-2"></i>
					@ViewBag.NombreCategoria
				</h4>
 *@
				@if (Model != null && Model.Any())
				{
					<div class="d-flex flex-wrap justify-content-center gap-3 mt-4">
						@foreach (var formato in Model)
						{
							<a class="boton-formatos d-flex align-items-center justify-content-center"
								   asp-area="Tecnologias"
								   asp-controller="Formatos"
								   asp-action="Descargar"
								   asp-route-id="@formato.IdFormato">
								<i class="bi bi-file-earmark-pdf me-2"></i>
								<span>@formato.Nombre</span>
							</a>
						}
					</div>
				}
				else
				{
					<div class="alert alert-warning mt-4">
						<i class="bi bi-info-circle me-2"></i>
						No hay formatos disponibles en este momento.
					</div>
				}

			</div>

		</div>
	</div>

	
	<div class="mt-5 text-center">
		<a asp-area="Tecnologias"
			   asp-controller="Inicio"
			   asp-action="Index"
			   class="btn btn-outline-danger btn-lg shadow-sm px-4">
			<i class="bi bi-arrow-left-circle me-2"></i>
			Volver al menú principal
		</a>
	</div>



</div>

<br />
