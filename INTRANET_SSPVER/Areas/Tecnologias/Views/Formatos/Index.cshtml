@model IEnumerable<INTRANET_SSPVER.Models.Entities.Formato>

@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}



<div class="container py-4">

	<!-- Card principal -->
	<div class="card shadow-sm border-0 formatos-card mx-auto">

		<!-- Header -->
		<div class="card-header  text-white d-flex align-items-center justify-content-between headertitulo">

			<a href="Inicio" class="btn btn-light btn-sm">
				<i class="bi bi-arrow-left"></i> Regresar
			</a>

			<div class="text-center flex-grow-1">
				<h4 class="mb-0 fw-bold">
					<i class="bi bi-file-earmark-text me-2"></i>
					@ViewBag.NombreCategoria
				</h4>
				<small class="text-light opacity-75">
					Descarga de formatos disponibles
				</small>
			</div>

			<div style="width:90px;"></div>

		</div>

		<!-- Body -->
		<div class="card-body">

			<!-- Buscador -->	

			<div class="input-group mb-3">
    <span class="input-group-text bg-white">
        <i class="bi bi-search"></i>
    </span>
    <input type="text" class="form-control" placeholder="Buscar formato..." id="buscarFormato">
</div>

			@if (Model != null && Model.Any())
			{
				<div class="row g-4" id="contenedorFormatos">

					@foreach (var formato in Model)
					{
						<div class="col-md-4 formato-item">
							<div class="card h-100 shadow-sm border-0 card-hover">

								<div class="card-body text-center">

									<!-- Icono dinámico -->
									<i class="bi bi-file-earmark-pdf text-danger fs-1"></i>

									<h6 class="mt-3 fw-semibold">@formato.Nombre</h6>

									<small class="text-muted d-block mb-3">
										Archivo PDF
									</small>

									<a class="btn btn-outline-primary btn-sm w-100"
										   asp-area="Tecnologias"
										   asp-controller="Formatos"
										   asp-action="Descargar"
										   asp-route-id="@formato.IdFormato">
										<i class="bi bi-download me-1"></i>
										Descargar
									</a>

								
								</div>

							</div>
						</div>
					}

				</div>
			}
			else
			{
				<div class="alert alert-warning text-center mt-4">
					<i class="bi bi-info-circle me-2"></i>
					No hay formatos disponibles en este momento.
				</div>
			}

		</div>

	</div>

</div>



<style>
@* 	.formatos-card {
		max-width: 1000px;
	}
 *@
	.card-hover {
		transition: all 0.2s ease;
		cursor: pointer;
	}

		.card-hover:hover {
			transform: translateY(-5px);
			box-shadow: 0 10px 25px rgba(0,0,0,0.15);
		}
</style>


<script>
	document.getElementById("buscarFormato").addEventListener("keyup", function () {
		let filtro = this.value.toLowerCase();
		let items = document.querySelectorAll(".formato-item");

		items.forEach(item => {
			let texto = item.innerText.toLowerCase();
			item.style.display = texto.includes(filtro) ? "" : "none";
		});
	});
</script>