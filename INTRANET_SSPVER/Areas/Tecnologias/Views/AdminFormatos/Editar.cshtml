

@model INTRANET_SSPVER.Models.Entities.Formato

@{
    ViewData["Title"] = "Editar formato";
}

<h2 class="mb-4 text-center text-uppercase text-primary">Editar Formato</h2>

<form asp-action="Editar" enctype="multipart/form-data" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="IdFormato" />

    <div class="mb-3">
        <label asp-for="Nombre" class="form-label">Nombre del formato</label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="IdArea" class="form-label">Área</label>
        <select asp-for="IdArea" asp-items="ViewBag.Areas" class="form-select"></select>
        <span asp-validation-for="IdArea" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Archivo actual</label>
        <p>
            <a href="@Model.RutaArchivo" target="_blank" class="btn btn-link">
                @Model.RutaArchivo
            </a>
        </p>
    </div>

    <div class="mb-3">
        <label for="archivo" class="form-label">Reemplazar archivo PDF (opcional)</label>
        <input type="file" name="archivo" id="archivo" class="form-control" accept="application/pdf" />
    </div>

    <div class="mb-3 form-check">
        <input asp-for="Activo" type="checkbox" class="form-check-input" />
        <label asp-for="Activo" class="form-check-label">Activo</label>
    </div>

    <button type="submit" class="btn btn-primary">
        <i class="bi bi-save me-2"></i> Guardar cambios
    </button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
