

@model INTRANET_SSPVER.Models.Entities.Formato



<form asp-action="Crear" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="IdArea" class="form-label">Área</label>
        <select asp-for="IdArea" asp-items="ViewBag.Areas" class="form-select"></select>
        <span asp-validation-for="IdArea" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Archivo PDF</label>
        <input type="file" name="archivo" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
</form>
