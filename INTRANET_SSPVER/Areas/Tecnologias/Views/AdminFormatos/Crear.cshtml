@model INTRANET_SSPVER.Models.Entities.TformatosTecnologia

@{
    ViewData["Title"] = "Subir nuevo formato";
}

<h2>Subir nuevo formato</h2>

<form asp-action="Crear" enctype="multipart/form-data" method="post" class="mt-3">
    <div class="mb-3">
        <label for="nombre" class="form-label">Nombre del formato</label>
        <input type="text" name="nombre" id="nombre" class="form-control" required />
    </div>

    <div class="mb-3">
        <label for="archivo" class="form-label">Archivo PDF</label>
        <input type="file" name="archivo" id="archivo" class="form-control" accept="application/pdf" required />
    </div>

    <button type="submit" class="btn btn-success">
        <i class="bi bi-upload me-2"></i> Guardar
    </button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
