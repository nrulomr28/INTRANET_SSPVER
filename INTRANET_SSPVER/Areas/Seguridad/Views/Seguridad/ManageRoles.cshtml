@using Microsoft.AspNetCore.Identity
@using INTRANET_SSPVER.Models.Authentication
@using INTRANET_SSPVER.Models.ViewModels.Admin

@model ManageRolesViewModel


@{
	ViewData["Title"] = "Gestión de Roles";

}

<div class="container mt-4">

	<div class="d-flex justify-content-between align-items-center mb-3">

		<h2 class="text-primary">
			<i class="bi bi-people-fill me-2"></i> Administración de Usuarios
		</h2>

		<a asp-area="Account" asp-controller="Account" asp-action="Register" class="btn btn-success">
			<i class="bi bi-person-plus-fill me-1"></i> Nuevo Usuario
		</a>

	</div>

	<!-- Mensajes de éxito/error -->
	@if (TempData["SuccessMessage"] != null)
	{
		<div class="alert alert-success alert-dismissible fade show" role="alert">
			<i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
			<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
		</div>
	}
	@if (TempData["ErrorMessage"] != null)
	{
		<div class="alert alert-danger alert-dismissible fade show" role="alert">
			<i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
			<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
		</div>
	}

	<!-- Tabla de usuarios -->
	<div class="card shadow-sm">
		<div class="card-body">

			<table class="table table-hover align-middle">

				<thead class="table-dark">
					<tr>
						<th><i class="bi bi-person-fill me-1"></i> Usuario</th>
						<th><i class="bi bi-envelope-fill me-1"></i> Email</th>
						<th><i class="bi bi-tags-fill me-1"></i> Roles asignados</th>
						<th><i class="bi bi-gear-fill me-1"></i> Acciones</th>
						<th><i class="bi bi-lock-fill me-1"></i> Bloqueo</th>
						<th><i class="bi bi-pass me-1"></i> Password</th>
						
					</tr>
				</thead>

				<tbody>

					@foreach (var user in Model.Users)
					{
						<tr>
							<td>@user.UserName</td>
							<td>@user.Email</td>
							<td>
								@if (user.Roles.Any())
								{
									@foreach (var role in user.Roles)
									{
										<span class="badge bg-info text-dark me-1">@role</span>
										<form asp-action="RemoveRole" method="post" class="d-inline">
											<input type="hidden" name="userId" value="@user.Id" />
											<input type="hidden" name="roleName" value="@role" />
											<button type="submit" class="btn btn-sm btn-outline-danger ms-1"
													onclick="return confirm('¿Está seguro de quitar el rol @role a @user.UserName?');">
												<i class="bi bi-x-circle"></i> Quitar
											</button>
										</form>
									}
								}
								else
								{
									<span class="text-muted fst-italic">Sin roles asignados</span>
								}

							</td>

							<td>
								<a asp-area="Seguridad" asp-controller="Seguridad" asp-action="MostrarRol" asp-route-id="@user.Id"
									   class="btn btn-sm btn-outline-primary">
									<i class="bi bi-plus-circle"></i> Asignar Rol
								</a>

								<td>
									@if (user.IsLockedOut)
									{
										<form asp-area="Seguridad" asp-controller="Seguridad" asp-action="DesbloquearUsuario" method="post" class="d-inline">
											<input type="hidden" name="id" value="@user.Id" />
											<button type="submit" class="btn btn-sm btn-success ms-1"
													onclick="return confirm('¿Está seguro de desbloquear al usuario @user.UserName?');">
												<i class="bi bi-unlock-fill"></i> Desbloquear
											</button>
										</form>
									}
									else
									{
										<form asp-area="Seguridad" asp-controller="Seguridad" asp-action="BloquearUsuario" method="post" class="d-inline">
											<input type="hidden" name="id" value="@user.Id" />
											<button type="submit" class="btn btn-sm btn-danger ms-1"
													onclick="return confirm('¿Está seguro de bloquear al usuario @user.UserName?');">
												<i class="bi bi-lock-fill"></i> Bloquear
											</button>
										</form>
									}


								</td>

								<td>

									<a asp-area="Seguridad" asp-controller="Seguridad" asp-action="ResetPasswordAdmin" asp-route-userId="@user.Id" class="btn btn-warning btn-sm">
										<i class="bi bi-lock-fill me-1"></i> Resetear contraseña
									</a>

								</td>

							</tr>
						}

					</tbody>

				</table>



			</div>
		</div>
	</div>



	@section Scripts {
		@{
			await Html.RenderPartialAsync("_ValidationScriptsPartial");
		}
	}


