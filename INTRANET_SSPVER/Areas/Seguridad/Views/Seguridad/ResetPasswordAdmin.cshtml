@using INTRANET_SSPVER.Models.ViewModels.Admin
@model ResetPasswordViewModel

@{
	ViewData["Title"] = "Resetear contraseña";
}

<div class="container mt-5">
	<div class="row justify-content-center">
		<div class="col-md-5">
			<div class="card shadow-sm">
				<div class="card-header bg-primary text-white">
					Resetear contraseña
				</div>
				<div class="card-body">
					<div asp-validation-summary="All" class="text-danger mb-3"></div>

					<form asp-action="ResetPasswordAdmin" method="post">
						<input type="hidden" asp-for="UserId" />

						<div class="mb-3">
							<label asp-for="NewPassword" class="form-label"></label>
							<input asp-for="NewPassword" class="form-control" />
							<span asp-validation-for="NewPassword" class="text-danger"></span>
						</div>

						<div class="mb-3">
							<label asp-for="ConfirmPassword" class="form-label"></label>
							<input asp-for="ConfirmPassword" class="form-control" />
							<span asp-validation-for="ConfirmPassword" class="text-danger"></span>
						</div>


						<div class="d-flex justify-content-sm-start mt-4  gap-3">

							<button type="submit" class="btn btn-outline-success">
								<i class="bi bi-person-plus-fill me-1"></i> Guardar
							</button>

							<a asp-action="MostrarUsuarios" class="btn btn-outline-danger">
								<i class="bi bi-arrow-left-circle me-1"></i>
								Cancelar
							</a>

						</div>


					</form>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}
