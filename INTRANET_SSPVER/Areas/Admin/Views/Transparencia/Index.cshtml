@using INTRANET_SSPVER.Models.ViewModels.Transparencia
@model List<TransparenciaVM>

@{
	ViewData["Title"] = "Administrar Comité de Transparencia";
}


<div class="container-fluid mt-4">

	<div class="card shadow-sm border-0">

		<!-- HEADER -->
		<div class="card-header text-white d-flex align-items-center justify-content-between headertitulo">

			<!-- Botón regresar -->
			<a href="/inicio" class="btn btn-sm btn-light shadow-sm">
				<i class="bi bi-arrow-left"></i> Regresar
			</a>

			<!-- Título centrado -->
			<div class="d-flex align-items-center mx-auto">
				<i class="bi bi-journal-text me-2 fs-4"></i>
				<h4 class="mb-0">Administración Comité de Transparencia</h4>
			</div>

		</div>

		<div class="card-body">

			<!-- BOTÓN NUEVO -->
			<div class="d-flex justify-content-end mb-3">
				<a asp-area="Admin"
					   asp-controller="Transparencia"
					   asp-action="Create"
					   class="btn btn-success shadow-sm px-3 rounded-pill">
					<i class="bi bi-plus-circle"></i> Nuevo Registro
				</a>
			</div>

			<!-- BUSCADOR -->
			<div class="mb-3 position-relative">
				<i class="bi bi-search position-absolute"
				   style="top:10px; left:10px; color:gray;"></i>

				<input type="text" id="searchBox"
					   class="form-control ps-4"
					   placeholder="Buscar por nombre, área o extensión..." />
			</div>

			<!-- ALERTAS -->
			@if (TempData["Success"] != null)
			{
				<div id="alertSuccess" class="alert alert-success alert-dismissible fade show shadow-sm">
					<i class="bi bi-check-circle me-2"></i>
					@TempData["Success"]
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>
			}

			@if (TempData["Error"] != null)
			{
				<div id="alertError" class="alert alert-danger alert-dismissible fade show shadow-sm">
					<i class="bi bi-exclamation-triangle me-2"></i>
					@TempData["Error"]
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>
			}

			<!-- TABLA -->
			<div class="table-responsive">
				<table class="table table-bordered table-hover align-middle" id="tablaDirectorio">

					<thead class="text-center" style="background-color:#f1f1f1;">
						<tr>
							<th style="width:10%">#</th>
							<th style="width:40%">NumeroActa</th>
							<th style="width:40%">Fecha</th>
							<th style="width:20%">Url</th>
						</tr>
					</thead>

					<tbody>
						@{
							int i = 1;
						}

						@foreach (var item in Model)
						{
							<tr>
								<td class="text-center">@i</td>
								<td>@item.NumeroActa</td>
								<td>@item.Fecha</td>
								<td>@item.Url</td>
								<td class="text-center">

									<!-- EDITAR -->
									<a asp-area="Admin"
										   asp-controller="Transparencia"
										   asp-action="Edit"
										   asp-route-id="@item.IdComite"
										   class="btn btn-sm btn-outline-secondary">
										<i class="bi bi-pencil-square"></i>
									</a>

									<!-- ELIMINAR -->
									<form asp-area="Admin"
										  asp-controller="Transparencia"
										  asp-action="Delete"
										  asp-route-id="@item.IdComite"
										  method="post"
										  style="display:inline;"
										  onsubmit="return confirm('¿Deseas eliminar este registro?');">

										@Html.AntiForgeryToken()

										<button type="submit" class="btn btn-sm btn-outline-danger">
											<i class="bi bi-trash"></i>
										</button>

									</form>

								</td>
							</tr>

							i++;
						}

					</tbody>

				</table>
			</div>

		</div>

	</div>

</div>





<script>
	document.getElementById("searchBox").addEventListener("keyup", function () {
		var value = this.value.toLowerCase();
		var rows = document.querySelectorAll("#tablaDirectorio tbody tr");

		let contador = 1;

		rows.forEach(function (row) {
			var text = row.textContent.toLowerCase();

			if (text.includes(value)) {
				row.style.display = "";
				row.cells[0].textContent = contador;
				contador++;
			} else {
				row.style.display = "none";
			}
		});
	});
</script>
										
<script>
	setTimeout(function () {
		let success = document.getElementById("alertSuccess");
		let error = document.getElementById("alertError");

		[success, error].forEach(function (alert) {
			if (alert) {
				alert.classList.remove("show");
				setTimeout(() => alert.remove(), 500);
			}
		});

	}, 3000);
</script> 