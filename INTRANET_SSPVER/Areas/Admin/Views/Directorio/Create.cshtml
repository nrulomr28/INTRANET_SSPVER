@using INTRANET_SSPVER.Models.ViewModels.Directorio
@model DirectorioFormVM

@{
	ViewData["Title"] = "Nuevo Registro";
}

<div class="container mt-4">

	<h4 class="fw-bold mb-3">
		<i class="bi bi-plus-circle me-2"></i> Nuevo Registro
	</h4>

	<form asp-action="Create" method="post">

		<div class="mb-3">
			<label class="form-label">Nombre</label>
			<input asp-for="Nombre" class="form-control" />
			<span asp-validation-for="Nombre" class="text-danger"></span>
		</div>

	
		<div class="mb-3">
			<label class="form-label">Área</label>

			<select asp-for="IdArea"
					asp-items="Model.Areas"
					class="form-select">
				<option value="">-- Selecciona un área --</option>
			</select>

			<span asp-validation-for="IdArea" class="text-danger"></span>
		</div>
		

		<div class="mb-3">
			<label class="form-label">Extensión</label>
			<input asp-for="Ext" class="form-control" />
			<span asp-validation-for="Ext" class="text-danger"></span>
		</div>

		<div class="d-flex justify-content-between">
			<a asp-action="Index" class="btn btn-secondary">
				<i class="bi bi-arrow-left"></i> Volver
			</a>

			<button type="submit" class="btn btn-success">
				<i class="bi bi-save"></i> Guardar
			</button>
		</div>

	</form>
</div>