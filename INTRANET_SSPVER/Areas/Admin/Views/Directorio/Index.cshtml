@using INTRANET_SSPVER.Models.ViewModels.Directorio
@model List<DirectorioListVM>

@{
	ViewData["Title"] = "Administrar Directorio";
}




<div class="container-fluid mt-4">

	<!-- HEADER -->
	<div class="d-flex justify-content-between align-items-center mb-3">
		<h4 class="fw-bold">
			<i class="bi bi-journal-text me-2"></i>
			Administración de Directorio
		</h4>

		<a asp-area="Admin"
			   asp-controller="Directorio"
			   asp-action="Create"
			   class="btn btn-success">
			<i class="bi bi-plus-circle"></i> Nuevo Registro
		</a>
	</div>

	<!-- BUSCADOR -->
	<div class="mb-3">
		<input type="text" id="searchBox"
			   class="form-control"
			   placeholder="Buscar por nombre, área o extensión..." />
	</div>


	@if (TempData["Success"] != null)
	{
		<div id="alertSuccess" class="alert alert-success alert-dismissible fade show">
			<i class="bi bi-check-circle me-2"></i>
			@TempData["Success"]
			<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
		</div>
	}

	@if (TempData["Error"] != null)
	{
		<div id="alertError" class="alert alert-danger alert-dismissible fade show">
			<i class="bi bi-exclamation-triangle me-2"></i>
			@TempData["Error"]
			<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
		</div>
	}

	<!-- TABLA -->
	<div class="table-responsive">
		<table class="table table-bordered table-hover table-sm align-middle" id="tablaDirectorio">

			<thead class="table-dark text-center">
				<tr>
					<th style="width:5%">#</th>
					<th>Nombre</th>
					<th>Área</th>
					<th style="width:15%">Extensión</th>
					<th style="width:15%">Acciones</th>
				</tr>
			</thead>

			<tbody>
				@{
					int i = 1;
				}

				@foreach (var item in Model)
				{
					<tr>
						<td class="text-center">@i</td>
						<td>@item.Nombre</td>
						<td>@item.Area</td>
						<td class="text-center">
							<i class="bi bi-telephone me-1"></i> @item.Ext
						</td>
						<td class="text-center">

							<!-- EDITAR -->
							<a asp-area="Admin"
								   asp-controller="Directorio"
								   asp-action="Edit"
								   asp-route-id="@item.Id"
								   class="btn btn-sm btn-primary">
								<i class="bi bi-pencil-square"></i>
							</a>

							

							<form asp-area="Admin"
								  asp-controller="Directorio"
								  asp-action="Delete"
								  asp-route-id="@item.Id"
								  method="post"
								  style="display:inline;"
								  onsubmit="return confirm('¿Deseas eliminar este registro?');">

								@Html.AntiForgeryToken()

								<button type="submit" class="btn btn-sm btn-danger">
									<i class="bi bi-trash"></i>
								</button>

							</form>

						</td>
					</tr>

					i++;
				}


			</tbody>

		</table>
	</div>

</div>


<script>
	document.getElementById("searchBox").addEventListener("keyup", function () {
		var value = this.value.toLowerCase();
		var rows = document.querySelectorAll("#tablaDirectorio tbody tr");

		let contador = 1;

		rows.forEach(function (row) {
			var text = row.textContent.toLowerCase();

			if (text.includes(value)) {
				row.style.display = "";
				row.cells[0].textContent = contador;
				contador++;
			} else {
				row.style.display = "none";
			}
		});
	});
</script>


<script>
	setTimeout(function () {
		let success = document.getElementById("alertSuccess");
		let error = document.getElementById("alertError");

		[success, error].forEach(function (alert) {
			if (alert) {
				alert.classList.remove("show");
				setTimeout(() => alert.remove(), 500);
			}
		});

	}, 3000);
</script>