@using INTRANET_SSPVER.Models.ViewModels.Calea
@model List<AreaCaleaVM>


@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}

@* <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script> *@




@if (TempData["Error"] != null)
{
	<script>
		Swal.fire({
		icon: 'error',
		title: 'Error...',
		text: '@TempData["Error"]',
		confirmButtonColor: '#6A1B1B'
		});
	</script>
}

@if (TempData["Success"] != null)
{
	<script>
		Swal.fire({
		icon: 'success',
		title: 'Correcto',
		text: '@TempData["Success"]',
		timer: 2500,
		showConfirmButton: false
		});
	</script>
}


<div class="container mb-2 mt-3">


	<div class="card-header text-center text-white d-flex align-items-center justify-content-between headertitulo">

		<!-- Botón regresar -->
		@* <a href="/inicio" class="btn btn-sm btn-light">
			<i class="bi bi-arrow-left"></i> Regresar
		</a> *@

		<a href="javascript:history.back()" class="btn btn-light btn-sm">
			<i class="bi bi-arrow-left"></i> Regresar
		</a>

		<!-- Título centrado -->
		<div class="d-flex align-items-center mx-auto">
			<i class="bi bi-award-fill me-2 fs-4"></i>
			<h4 class="mb-0">CALEA</h4>
		</div>


		<!-- Espacio para balancear -->
		<div style="width: 90px;"></div>
	</div>

	
	<!-- 🔹 Videos -->
	<div class="row mb-4 mt-3">

		<div class="col-md-6">
			<div class="card p-2 shadow-sm">
				@* <video controls width="100%" style="border-radius:10px;">
					<source src="~/videos/video1.mp4" type="video/mp4">
					Tu navegador no soporta video.
				</video> *@

				<video controls width="100%">
					<source src="@Url.Content("~/Calea/Videos/Calea.mp4")" type="video/mp4">
				</video>
			</div>
			<p class="text-center">¿Qué es CALEA?</p>
		</div>

		<div class="col-md-6">
			<div class="card p-2 shadow-sm">
				<video controls width="100%" style="border-radius:10px;">
					@* <source src="~/videos/video2.mp4" type="video/mp4"> *@
					<source src="@Url.Content("~/Calea/Videos/Beneficios.mp4")" type="video/mp4">
					Tu navegador no soporta video.
				</video>
			</div>
			<p class="text-center">Beneficios de la acreditación CALEA</p>
		</div>

	</div>

</div>


<div class="text-center mb-4">
	<h3 class="fw-bold">DIRECTIVAS</h3>
	<p class="text-muted">Consulta y descarga las directivas institucionales</p>
</div>


<div class="accordion" id="accordionCalea">

	@foreach (var area in Model)
	{
		var collapseId = "collapse_" + area.IdArea;

		<div class="accordion-item mb-3 shadow-sm">

			<!-- HEADER -->
			<h2 class="accordion-header">
				<button class="accordion-button collapsed fw-bold" type="button"
						data-bs-toggle="collapse"
						data-bs-target="#@collapseId">
					@area.NombreArea
				</button>
			</h2>

			<!-- CONTENIDO -->
			<div id="@collapseId" class="accordion-collapse collapse"
				 data-bs-parent="#accordionCalea">

				<div class="accordion-body">

					<div class="row">
						
						@foreach (var d in area.Directivas)
						{
							<div class="col-md-6 mb-3">

								@if (d.ArchivoDisponible)
								{
									<button type="button"
											class="archivo-card d-flex align-items-center border-0 w-100 text-start btn-pdf"
											data-id="@d.IdDirectiva">

										<div class="icono">
											<i class="bi bi-file-earmark-pdf"></i>
										</div>

										<div class="info flex-grow-1">
											<div class="titulo">
												@d.NombreDirectiva
											</div>

											<div class="sub">
												Descargar archivo
											</div>
										</div>

										<div class="descarga">
											<i class="bi bi-download"></i>
										</div>

									</button>
								}
								else
								{
									<div class="archivo-card d-flex align-items-center opacity-50">

										<div class="icono">
											<i class="bi bi-file-earmark-x"></i>
										</div>

										<div class="info flex-grow-1">
											<div class="titulo">
												@d.NombreDirectiva
											</div>

											<div class="sub text-danger">
												Archivo no disponible
											</div>
										</div>

									</div>
								}

							</div>
						}

					</div>
				</div>
			</div>
		</div>
	}

</div>

								

@section Scripts {
	<script>

				document.querySelectorAll(".btn-pdf")
			.forEach(btn => {

			btn.addEventListener("click", async function () {

				const id = this.dataset.id;

				const response = await fetch(
					`/Calea/Archivo/ExistePdf?id=${id}`
				);

				const existe = await response.json();

				if (existe)
				{
					window.open(
						`/Calea/Archivo/VerPdf?id=${id}`,
						'_blank'
					);
				}
				else
				{
					Swal.fire({
						icon: 'error',
						title: 'Archivo no disponible',
						text: 'El archivo no existe en el repositorio.',
						confirmButtonColor: '#6A1B1B'
					});
				}

			});

		});

	</script>

}

									