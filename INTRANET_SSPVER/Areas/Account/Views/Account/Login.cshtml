@using INTRANET_SSPVER.Models.Authentication
@model LoginViewModel

@{
	
	Layout = "~/Views/Shared/_LayoutLogin.cshtml";
	ViewData["Title"] = "Iniciar sesión";
}



@if (!ViewData.ModelState.IsValid)
{
	<div class="alert alert-danger-strong alert-dismissible fade show mx-auto text-center" role="alert"
		 style="max-width:420px; border-radius:0.5rem;">
		<i class="bi bi-exclamation-triangle-fill me-2"></i>
		@foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
		{
			<div>@error.ErrorMessage</div>
		}
		<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
	</div>
}






<div class="container mt-5">
	<div class="row justify-content-center mt-5">
		<div class="col-md-5">
			<div class="card shadow-sm rounded-4 p-4 border-0">
								

				<div class="d-flex justify-content-center align-items-center gap-4 mt-2">
					<img src="~/img/logo/LogoIntranet.png" alt="Imagen de login"
						 class="img-fluid" style="max-height:60px;" />
					@* <img src="~/img/logo/Logo_Intranet.png" alt="Imagen de login"
						 class="img-fluid" style="max-height:60px;" /> *@
				</div>


				<div class="row mt-5">

					<h2 class="mb-4 text-center text-primary">
						<i class="bi bi-box-arrow-in-right me-2"></i>Iniciar sesión
					</h2>

				</div>

				

				@* @Html.ValidationSummary(true, "", new { @class = "text-danger" }) *@


				

				<form asp-area="Account" asp-controller="Account" asp-action="Login" method="post">
					@Html.AntiForgeryToken()

					<div class="form-group mb-3">
						<label for="UserName" class="form-label">Nombre de usuario</label>
						<input type="text" class="form-control" id="UserName" name="UserName"
							   value="@Model?.UserName" placeholder="Ingresa tu usuario"
							   autocomplete="username" required />
						@* @if (ViewData.ModelState.ContainsKey("UserName"))
						{
							<span class="text-danger small">
								@ViewData.ModelState["UserName"].Errors.FirstOrDefault()?.ErrorMessage
							</span>
						} *@
					</div>

					<div class="form-group mb-3">
						<label for="Password" class="form-label">Contraseña</label>
						<input type="password" class="form-control" id="Password" name="Password"
							   placeholder="Ingresa tu contraseña" autocomplete="current-password" required />
						@* @if (ViewData.ModelState.ContainsKey("Password"))
						{
							<span class="text-danger small">
								@ViewData.ModelState["Password"].Errors.FirstOrDefault()?.ErrorMessage
							</span>
						} *@
					</div>

					<div class="form-check mb-3">
						<input class="form-check-input" id="RememberMe" name="RememberMe" type="checkbox" />
						<label for="RememberMe" class="form-check-label">Recordarme</label>
					</div>

					<button type="submit" class="btn btn-primary w-100">
						<i class="bi bi-door-open-fill me-2"></i>Ingresar
					</button>
					<br />
					<br />

					<!-- Imagen debajo del botón -->
					@* 	<div class="text-center">
						<img src="~/img/TI.jpg" alt="Imagen de login" class="img-fluid mt-2" style="max-height:100px;" />
					</div> *@




					<div class="d-flex justify-content-center align-items-center gap-4 mt-2">
						<img src="~/img/veracruz/Veracruz2025_2.png" alt="Imagen de login"
							 class="img-fluid" style="max-height:60px;" />
						<img src="~/img/veracruz/TI.jpg" alt="Imagen de login"
							 class="img-fluid" style="max-height:60px;" />
					</div>



					


				</form>
			</div>
		</div>
	</div>
</div>


@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}
